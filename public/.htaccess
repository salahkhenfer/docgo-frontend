# ── Disable MultiViews (prevents Apache content-negotiation breaking SPA routes)
Options -MultiViews

# ── HTTPS redirect + React Router SPA fallback ───────────────────────────────
# IMPORTANT: both rules must be in ONE RewriteEngine block so Apache applies
# them in order. Splitting into two blocks causes intermittent SPA 404s.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Force HTTPS — redirect and stop (L). The request comes back on HTTPS
    #    and skips this rule because %{HTTPS} is no longer "off".
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # 2. SPA fallback — only runs on HTTPS requests (HTTP was already redirected).
    #    Serve index.html for any path that is not a real file or directory.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [QSA,L]
</IfModule>

# ── Security headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set X-XSS-Protection "1; mode=block"
    # Remove server info
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# ── Gzip compression ─────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# ── Browser caching ──────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    # Vite hashes JS/CSS filenames — cache forever
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/css                "access plus 1 year"
    # Images and fonts
    ExpiresByType image/png               "access plus 1 year"
    ExpiresByType image/jpeg              "access plus 1 year"
    ExpiresByType image/svg+xml           "access plus 1 year"
    ExpiresByType image/x-icon            "access plus 1 year"
    ExpiresByType image/webp              "access plus 1 year"
    ExpiresByType font/woff               "access plus 1 year"
    ExpiresByType font/woff2              "access plus 1 year"
    # index.html must never be cached (SPA entry point)
    ExpiresByType text/html               "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    # index.html: always revalidate
    <FilesMatch "^index\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    # Hashed assets: cache forever
    <FilesMatch "\.(js|css|woff|woff2|ttf|eot|png|jpg|jpeg|svg|ico|webp)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>


