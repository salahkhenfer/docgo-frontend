# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=ce15f09aba8c461ea95db36c370d18d3
# VITE_API_URL=http://localhost:3000
# DEV_AUTH_ENABLED = true
# VITE_DEV_USER_EMAIL=student1@example.com
# VITE_DEV_USER_PASSWORD=password123


# healthpathglobal Frontend (Vite) environment

# Backend base URL (scheme + domain + optional path, no trailing slash)
# Examples:
#   VITE_API_URL=http://localhost:3000
# NOTE:
# - Production builds should NEVER point to localhost.
# - For local dev, use `.env.development` (created in this repo) to override this.
VITE_API_URL=https://backend.healthpathglobal.com

# Optional (recommended for SEO): the public site base URL used to build canonical URLs
# Examples:
#   VITE_SITE_URL=https://healthpathglobal.com
#   VITE_SITE_URL=https://www.healthpathglobal.com
VITE_SITE_URL=https://healthpathglobal.com

# Optional: site name used in <title> suffix and Open Graph metadata
# VITE_SITE_NAME=healthpathglobal

# Builder.io
# VITE_PUBLIC_BUILDER_KEY=
